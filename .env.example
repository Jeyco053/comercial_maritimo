# Copia este archivo a .env y rellena los valores.
# (.env está ignorado por git — nunca subas claves.)

# Clave de API de Retell (la misma que usas en Bookia).
RETELL_API_KEY=

# Opcional: ID del agente setter, para que fetch-calls.mjs filtre solo sus llamadas
# y no mezcle con las del agente de Bookia. También lo usa test-call.mjs para forzar el agente.
RETELL_AGENT_ID=

# Para lanzar llamadas de prueba (scripts/test-call.mjs):
# Número que tengas dado de alta en Retell, en E.164. Al empezar, el que te da
# Retell (US/CA, +1...). Para la campaña real en España: un +34 800/900 vía Twilio.
RETELL_FROM_NUMBER=
